#include <stdlib.h>
#include <limits.h>

#define MAX 10005

typedef struct {
    int node;
    int dist;
} HeapNode;

typedef struct Edge {
    int to;
    int weight;
    struct Edge* next;
} Edge;

HeapNode heap[MAX];
int heapSize;

Edge* graph[101];

Edge* createEdge(int to, int weight) {
    Edge* newEdge = (Edge*)malloc(sizeof(Edge));
    newEdge->to = to;
    newEdge->weight = weight;
    newEdge->next = NULL;
    return newEdge;
}

void addEdge(int u, int v, int w) {
    Edge* newEdge = createEdge(v, w);
    newEdge->next = graph[u];
    graph[u] = newEdge;
}

void swap(HeapNode* a, HeapNode* b) {
    HeapNode temp = *a;
    *a = *b;
    *b = temp;
}

void push(int node, int dist) {
    heapSize++;

    heap[heapSize].node = node;
    heap[heapSize].dist = dist;

    int i = heapSize;

    while (i > 1 && heap[i].dist < heap[i / 2].dist) {
        swap(&heap[i], &heap[i / 2]);
        i = i / 2;
    }
}

HeapNode pop() {
    HeapNode minNode = heap[1];

    heap[1] = heap[heapSize];
    heapSize--;

    int i = 1;

    while (1) {
        int left = 2 * i;
        int right = 2 * i + 1;
        int smallest = i;

        if (left <= heapSize && heap[left].dist < heap[smallest].dist) {
            smallest = left;
        }

        if (right <= heapSize && heap[right].dist < heap[smallest].dist) {
            smallest = right;
        }

        if (smallest == i) {
            break;
        }

        swap(&heap[i], &heap[smallest]);
        i = smallest;
    }

    return minNode;
}

int networkDelayTime(int** times, int timesSize, int* timesColSize, int n, int k) {
    int dist[101];

    for (int i = 1; i <= n; i++) {
        graph[i] = NULL;
        dist[i] = INT_MAX;
    }

    heapSize = 0;

    for (int i = 0; i < timesSize; i++) {
        int u = times[i][0];
        int v = times[i][1];
        int w = times[i][2];

        addEdge(u, v, w);
    }

    dist[k] = 0;
    push(k, 0);

    while (heapSize > 0) {
        HeapNode current = pop();

        int node = current.node;
        int currentDist = current.dist;

        if (currentDist > dist[node]) {
            continue;
        }

        Edge* temp = graph[node];

        while (temp != NULL) {
            int next = temp->to;
            int weight = temp->weight;

            if (dist[node] + weight < dist[next]) {
                dist[next] = dist[node] + weight;
                push(next, dist[next]);
            }

            temp = temp->next;
        }
    }

    int answer = 0;

    for (int i = 1; i <= n; i++) {
        if (dist[i] == INT_MAX) {
            return -1;
        }

        if (dist[i] > answer) {
            answer = dist[i];
        }
    }

    return answer;
}