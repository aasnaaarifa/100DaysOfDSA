#include <stdlib.h>
typedef struct {
    int num;
    int freq;
} Node;
void swap(Node* a, Node* b){
    Node temp = *a;
    *a = *b;
    *b = temp;
}
void heapifyUp(Node heap[], int i){
    while(i > 0){
        int p = (i - 1) / 2;
        if(heap[p].freq > heap[i].freq){
            swap(&heap[p], &heap[i]);
            i = p;
        } else break;
    }
}
void heapifyDown(Node heap[], int size, int i){
    while(1){
        int l = 2*i + 1;
        int r = 2*i + 2;
        int s = i;

        if(l < size && heap[l].freq < heap[s].freq) s = l;
        if(r < size && heap[r].freq < heap[s].freq) s = r;

        if(s != i){
            swap(&heap[i], &heap[s]);
            i = s;
        } else break;
    }
}

int* topKFrequent(int* nums, int numsSize, int k, int* returnSize) {
    
    int offset = 10000;
    int freq[20001] = {0};

    for(int i = 0; i < numsSize; i++)
        freq[nums[i] + offset]++;

    Node heap[k];
    int size = 0;

    for(int i = 0; i < 20001; i++){
        if(freq[i] > 0){
            Node node;
            node.num = i - offset;
            node.freq = freq[i];

            if(size < k){
                heap[size] = node;
                heapifyUp(heap, size);
                size++;
            }
            else if(node.freq > heap[0].freq){
                heap[0] = node;
                heapifyDown(heap, k, 0);
            }
        }
    }

    int* result = (int*)malloc(sizeof(int) * k);

    for(int i = 0; i < k; i++)
        result[i] = heap[i].num;

    *returnSize = k;
    return result;
}
