//Problem Statement:Implement a Priority Queue using an array. An element with smaller value has higher priority.

#include <stdio.h>
#include <stdlib.h>
#include <string.h>

typedef struct {
    int* arr;
    int size;
    int capacity;
} PriorityQueue;

PriorityQueue* createQueue(int capacity) {
    PriorityQueue* pq = (PriorityQueue*)malloc(sizeof(PriorityQueue));
    pq->arr = (int*)malloc(sizeof(int) * capacity);
    pq->size = 0;
    pq->capacity = capacity;
    return pq;
}

void insert(PriorityQueue* pq, int value) {
    if (pq->size == pq->capacity) {
        printf("Queue full. Cannot insert %d\n", value);
        return;
    }
    pq->arr[pq->size++] = value;
    printf("%d inserted.\n", value);
}

int deleteMin(PriorityQueue* pq) {
    if (pq->size == 0) return -1;
    int minIndex = 0;
    for (int i = 1; i < pq->size; i++)
        if (pq->arr[i] < pq->arr[minIndex])
            minIndex = i;
    int minVal = pq->arr[minIndex];
    for (int i = minIndex; i < pq->size - 1; i++)
        pq->arr[i] = pq->arr[i + 1];
    pq->size--;
    return minVal;
}

int peek(PriorityQueue* pq) {
    if (pq->size == 0) return -1;
    int minVal = pq->arr[0];
    for (int i = 1; i < pq->size; i++)
        if (pq->arr[i] < minVal)
            minVal = pq->arr[i];
    return minVal;
}

int main() {
    int capacity = 1000; 
    PriorityQueue* pq = createQueue(capacity);
    char command[20];
    int value;

    printf("Priority Queue Interactive Mode\n");
    printf("Commands: insert | delete | peek | exit\n");

    while (1) {
        printf("Enter command: ");
        scanf("%s", command);

        if (strcmp(command, "insert") == 0) {
            scanf("%d", &value);
            insert(pq, value);
        } else if (strcmp(command, "delete") == 0) {
            int val = deleteMin(pq);
            if (val == -1) printf("-1\n");
            else printf("Deleted: %d\n", val);
        } else if (strcmp(command, "peek") == 0) {
            int val = peek(pq);
            printf("%d\n", val);
        } else if (strcmp(command, "exit") == 0) {
            break;
        } else {
            printf("Invalid command.\n");
        }
    }

    free(pq->arr);
    free(pq);
    return 0;
}
