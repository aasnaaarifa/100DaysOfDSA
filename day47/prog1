//Problem: Height of Binary Tree Implement the solution for this problem

#include <stdio.h>
#include <stdlib.h>
#include <math.h>
int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    int count = 0;

    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
        if(arr[i] != -1) {
            count++;
        }
    }

    int height = 0;

    while(count > 0) {
        count = count / 2;
        height++;
    }

    printf("%d", height);

    return 0;
}
