//Problem: Level Order Traversal Implement the solution for this problem.

#include <stdio.h>
#include <stdlib.h>
int main() {
    int n;
    scanf("%d", &n);

    int arr[n];
    for(int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    for(int i = 0; i < n; i++) {
        if(arr[i] != -1) {
            printf("%d ", arr[i]);
        }
    }

    return 0;
}
