//Problem: Given an array of integers, find two elements whose sum is closest to zero.

#include <stdio.h>
#include <stdlib.h>
int main() {
    int n, i, j;
    printf("Enter the number of elements: ");
    scanf("%d", &n);
    int arr[n];
    printf("Enter %d integers:\n", n);
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    int min_sum = arr[0] + arr[1];
    int num1 = arr[0], num2 = arr[1];
    for(i = 0; i < n-1; i++) {
        for(j = i+1; j < n; j++) {
            int sum = arr[i] + arr[j];

            if(abs(sum) < abs(min_sum)) {
                min_sum = sum;
                num1 = arr[i];
                num2 = arr[j];
            }
        }
    }
    printf("\nPair whose sum is closest to zero: %d %d\n", num1, num2);
    return 0;
}
