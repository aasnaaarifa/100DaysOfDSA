//Problem: Given an array of integers, count the frequency of each distinct element and print the result.

#include <stdio.h>
struct freq {
    int element;
    int count;
};
int main() {
    int n, i, j, found;
    scanf("%d", &n);
    int arr[n];
    struct freq f[n];
    int size = 0;
    for(i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }
    for(i = 0; i < n; i++) {
        found = 0;
        for(j = 0; j < size; j++) {
            if(arr[i] == f[j].element) {
                f[j].count++;
                found = 1;
                break;
            }
        }
        if(!found) {
            f[size].element = arr[i];
            f[size].count = 1;
            size++;
        }
    }
    for(i = 0; i < size; i++) {
        printf("%d:%d ", f[i].element, f[i].count);
    }
    return 0;
}
