//Problem: Using DFS and parent tracking, detect if undirected graph has a cycle.

#include <stdio.h>
#define MAX 100

int graph[MAX][MAX];
int visited[MAX];

int dfs(int node, int parent, int n) {
    visited[node] = 1;

    for (int i = 0; i < n; i++) {
        if (graph[node][i] == 1) {
            if (!visited[i]) {
                if (dfs(i, node, n)) {
                    return 1;
                }
            } else if (i != parent) {
                return 1;
            }
        }
    }

    return 0;
}

int hasCycle(int n) {
    for (int i = 0; i < n; i++) {
        if (!visited[i]) {
            if (dfs(i, -1, n)) {
                return 1;
            }
        }
    }
    return 0;
}

int main() {
    int n;

    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        visited[i] = 0;
        for (int j = 0; j < n; j++) {
            scanf("%d", &graph[i][j]);
        }
    }

    if (hasCycle(n)) {
        printf("YES");
    } else {
        printf("NO");
    }

    return 0;
}